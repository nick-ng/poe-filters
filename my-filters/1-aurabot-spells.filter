	LinkedSockets <= 4
	SocketGroup = RRGG
	SetBorderColor 200 0 0 230
	SetBackgroundColor 88 0 87 255
	Class "Gloves" "Boots" "Gloves" "Body Armours"
	SetFontSize 40

Show
