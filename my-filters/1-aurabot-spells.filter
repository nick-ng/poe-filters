# Aurabot
# Leveling:
# 1-27: Rolling Magma
# 28+: Armageddon Brand + Vaal Flame Blast
# Leveling Items
Show
	BaseType "Heavy Belt"
	AreaLevel < 30
	Rarity <= Rare
	SetFontSize 45
	MinimapIcon 1 Cyan Star
	#!BrightBorder!# 200
	CustomAlertSound "sounds/cassia_what-do-we-have.mp3"

Show
  AreaLevel <= 10
  BaseType "Goat's Horn"
  SetFontSize 45
  #!DefaultBackground!# 120
  #!GoodBaseBorder!# 200
  PlayEffect Red
  #! tts "goat horn" goat-horn Amy 200 1.0
  MinimapIcon 1 Pink Star

Show
  AreaLevel <= 40
  BaseType "Faun's Horn"
  SetFontSize 45
  #!DefaultBackground!# 120
  #!GoodBaseBorder!# 200
  PlayEffect Red
  #! tts "faun horn" faun-horn Amy 200 1.0
  MinimapIcon 1 Pink Star

Show
  AreaLevel <= 67
  BaseType "Demon's Horn"
  SetFontSize 45
  #!DefaultBackground!# 120
  #!GoodBaseBorder!# 200
  PlayEffect Red
  #! tts "demon horn" demon-horn Amy 200 1.0
  MinimapIcon 1 Pink Star

#! linksa RBBB
#! linksa BBBB
#! linksa RBB
#! linksa BBB
#! linksa BB

# Party Links
Show
	AreaLevel <= 43
	Sockets < 6
	Rarity <= Rare
	LinkedSockets <= 4
	SocketGroup = RGGG
	SetBorderColor 200 0 0 230
	SetBackgroundColor 88 0 87 255
	Class "Gloves" "Boots" "Gloves" "Body Armours"
	SetFontSize 40

Show
	AreaLevel <= 43
	Sockets < 6
	Rarity <= Rare
	LinkedSockets <= 4
	SocketGroup = GGGG
	SetBorderColor 200 0 0 230
	SetBackgroundColor 88 0 87 255
	Class "Gloves" "Boots" "Gloves" "Body Armours"
	SetFontSize 40

Show
