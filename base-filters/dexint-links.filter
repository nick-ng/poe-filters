#! custombig SetBackgroundColor 88 0 87 255
#! custombig DisableDropSound
#! custombig MinimapIcon 0 Cyan Square
#! custombig CustomAlertSound "sounds/daniel-boots-4-link.mp3"

Show
	AreaLevel <= 36
	Class == "Gloves"
	Rarity <= Rare
	LinkedSockets == 4
	BaseEnergyShield >= 1
	BaseEvasion >= 1
	SetFontSize 45
	SetBorderColor 200 0 0 230
	SetBackgroundColor 88 0 87 255
	DisableDropSound
	MinimapIcon 0 Cyan Triangle
	CustomAlertSound "sounds/daniel-gloves-4-link.mp3"

